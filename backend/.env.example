# ─── Supabase + secrets ───
SUPABASE_URL=
SUPABASE_KEY=your-service-role-key-here
SECRET_KEY=your-secret-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Pi-hosted refactor: frontend->Pi auth (NEW) ───
# Shared secret for /api/device/* (X-Device-API-Key header). Frontend
# uses the same value as NEXT_PUBLIC_DEVICE_API_KEY. Must be >=16 chars
# unless BACKEND_HEADLESS=1 or PHARMGUARD_STUB=1.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEVICE_API_KEY=
# Set to 1 ONLY on dev-mac (no GPIO). Skips the hardware lifespan but
# still serves the HTTP API. /api/device/* returns 503 in headless mode.
BACKEND_HEADLESS=0

# ─── Legacy bearer auth (still valid for /api/inventory, /api/logs,
# ─── /api/auth/verify-face — internal cycle bypasses HTTP) ───
# Comma-separated list of valid bearer tokens.
DEVICE_TOKENS=

# ─── Dispenser identity ───
# Default fallback when a slot row has no dispenser_id (used by inventory API).
DEFAULT_DISPENSER_ID=dispenser-001
# THIS Pi's identifier — tags adherence + temperature events; leave empty for single-device deploys.
DISPENSER_ID=

# ─── Vision ───
# Face match acceptance threshold (Euclidean distance); tighten for stricter ID.
FACE_MATCH_TOLERANCE=0.6

# ─── AWS Rekognition (shared: face verify + intake label detection) ───
# Leave empty to disable both layers — services surface 503 / soft-fail at call time.
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Layer-2 intake label detection (DetectLabels) ───
# Hard-gate intake: MediaPipe FSM pass PLUS at least one required label.
# Set INTAKE_LABEL_ENABLED=0 to restore MediaPipe-only behavior.
INTAKE_LABEL_ENABLED=1
# CSV — any one match (case-insensitive) is enough for the gate.
INTAKE_LABEL_REQUIRED=Bottle,Cup,Mug,Drink,Drinking,Pill
INTAKE_LABEL_MIN_CONFIDENCE=70
# Seconds between DetectLabels calls during intake window.
# 1.5s x 60s window ~= 40 calls x $0.001 = ~$0.04/round.
INTAKE_LABEL_POLL_INTERVAL_S=1.5

# ─── Phase 5 alert thresholds ───
EXPIRY_WARN_DAYS=14
LOW_STOCK_THRESHOLD=3

# ─── Cycle cadence + stub ───
# Seconds between cycle attempts (asyncio.wait_for in HardwareLoop).
POLL_INTERVAL_S=30
# Set to 1 ONLY for dev with no real GPIO/camera. The cycle never logs
# pill_taken=true under stub mode (HI-012 invariant).
PHARMGUARD_STUB=0

# ─── Phase 6 bench (BENCH_MODE refuses to run on stubbed hardware) ───
BENCH_MODE=0
BENCH_LOG_PATH=/tmp/bench_e2e.csv

# ─── Phase 8 offline queue (durable buffer for adherence + temperature) ───
# Defaults to ~/.pharmguard/queue.db when empty. Override only if needed.
OFFLINE_QUEUE_PATH=
OFFLINE_MAX_AGE_SECONDS=3600
OFFLINE_REPLAY_INTERVAL_S=30

# ─── Clinician assistant (read-only Gemini agent) ───
# PHI DISCLAIMER: enabling the assistant sends patient data
# (names, conditions, adherence rows, alert payloads) to Google's
# Gemini API in plaintext. Operator opted in — keep GEMINI_API_KEY
# unset to fully disable both /api/agent/* endpoints and the
# scheduled brief (they will return 503 / silently skip).
AGENT_MODEL_NAME=gemini-2.0-flash
# CSV of LOCAL hours (24h) when the shift-handover brief is generated.
# Empty value disables the scheduler (manual /api/agent/brief still works).
AGENT_BRIEF_LOCAL_HOURS=7,19
# A missed-dose streak shorter than this (within 24 h) does NOT flag.
AGENT_FLAG_MISSED_STREAK_THRESHOLD=3
# Confidence below which a successful intake gets a low-confidence flag.
AGENT_FLAG_LOW_CONFIDENCE_THRESHOLD=0.55
# Set 0/false to skip the Gemini soft-pattern pass even when GEMINI_API_KEY is set.
AGENT_FLAG_GEMINI_ENABLED=1
