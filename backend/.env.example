SUPABASE_URL=
SUPABASE_KEY=your-service-role-key-here
SECRET_KEY=your-secret-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# Comma-separated list of valid Pi device tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEVICE_TOKENS=
# Default dispenser identifier for single-device deploys. Override per-Pi via DISPENSER_ID env on edge_pi.
DEFAULT_DISPENSER_ID=dispenser-001
# Face match acceptance threshold (Euclidean distance); tighten for stricter ID
FACE_MATCH_TOLERANCE=0.6

# Phase 5 alert thresholds — tune per pilot site / clinical SME sign-off.
# Days before expiry that triggers an `expiry` alert on /api/alerts/scan.
EXPIRY_WARN_DAYS=14
# medications.quantity at-or-below this triggers a `low_stock` alert.
LOW_STOCK_THRESHOLD=3
# Pi temperature post above this (Celsius) triggers an `over_temperature` alert.
OVER_TEMP_CELSIUS=30.0
