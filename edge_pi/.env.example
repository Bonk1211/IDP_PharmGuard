# Pi → backend connection
BACKEND_URL=https://pharmguard.example.com
DEVICE_TOKEN=replace-with-secure-token-from-secrets-token-urlsafe-32

# Polling cadence (seconds)
POLL_INTERVAL_S=30

# Set to 1 ONLY for dev with no real GPIO/camera. Allows http:// and stub hardware.
# In stub mode the device will NEVER report pill_taken=true (telemetry safety).
PHARMGUARD_STUB=0

# Optional: identifier reported with every adherence log. Leave blank for single-device deploys.
DISPENSER_ID=
