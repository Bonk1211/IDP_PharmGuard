NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# FastAPI backend base URL (used by enrollFace and other backend-routed helpers)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Pi device control (Pi-hosted-backend refactor) ──
# The Pi runs the FastAPI backend on its localhost; ngrok exposes it.
# Free-tier ngrok URL rotates per Pi reboot — operator must update this
# value and redeploy the dashboard each time.
NEXT_PUBLIC_DEVICE_URL=https://your-rotating-id.ngrok-free.app
# Shared secret matching backend settings.device_api_key. SOFT key — visible
# in the browser bundle; defence-in-depth alongside the un-guessable URL.
NEXT_PUBLIC_DEVICE_API_KEY=replace-with-secrets.token_urlsafe-32

# Default dispenser id for the "Dispenser" nav tab. Mirror of the
# backend DEFAULT_DISPENSER_ID. Single-tenant pilots can leave this
# at "dispenser-001".
NEXT_PUBLIC_DEFAULT_DISPENSER_ID=dispenser-001
